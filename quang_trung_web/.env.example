LLM_TIMEOUT_SECONDS=18
LLM_PROVIDER=gemini_api

# Use this only when LLM_PROVIDER=gemini_api.
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_ROUTER_MODEL_NAME=gemini-2.5-flash

# Use these when LLM_PROVIDER=vertex. Authenticate with gcloud ADC on the host.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

GOOGLE_TTS_API_KEY=
GOOGLE_TTS_TIMEOUT_SECONDS=18

RAG_SCORE_THRESHOLD=0.42
RAG_TOP_K=4
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_INDEX_DIR=
