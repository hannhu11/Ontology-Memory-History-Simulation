"use client";

import { useEffect, useState, useRef, useCallback } from "react";
import { useIntroCanvas } from "./IntroCanvas";
import { useIntroAudio } from "./IntroAudio";

interface SubtitleToken {
  text: string;
  start: number;
  end: number;
}

const CHAPTER_SUBTITLES: Record<number, SubtitleToken[]> = {
  0: [
    { text: "Mùa xuân năm ", start: 0, end: 1.2 },
    { text: "Kỷ Dậu 1789...", start: 1.2, end: 3.8 }
  ],
  1: [
    { text: "Từ nông dân áo vải Bình Định, ", start: 3.8, end: 5.5 },
    { text: "Nguyễn Huệ dựng cờ Tây Sơn ", start: 5.5, end: 7.5 },
    { text: "diệt giặc ngoại xâm, ", start: 7.5, end: 9.0 },
    { text: "dẹp loạn căn cứ, ", start: 9.0, end: 10.0 },
    { text: "lên ngôi Hoàng đế, ", start: 10.0, end: 10.8 },
    { text: "thiết lập kỷ nguyên mới cho dân tộc.", start: 10.8, end: 11.5 }
  ],
  2: [
    { text: "Tôn Sĩ Nghị kiêu ngạo kéo đại quân ", start: 11.5, end: 13.5 },
    { text: "chiếm đóng kinh thành Thăng Long. ", start: 13.5, end: 15.5 },
    { text: "Lê Chiêu Thống bán nước cầu vinh, ", start: 15.5, end: 17.5 },
    { text: "nhân dân lầm than trong ách áp bức hiểm nguy.", start: 17.5, end: 19.5 }
  ],
  3: [
    { text: "“Đánh cho để tóc dài, ", start: 19.5, end: 21.5 },
    { text: "Đánh cho để răng đen, ", start: 21.5, end: 23.0 },
    { text: "Đánh cho nó chích luân bất phản, ", start: 23.0, end: 25.5 },
    { text: "Đánh cho nó phiến giáp bất hoàn, ", start: 25.5, end: 27.5 },
    { text: "Đánh cho sử tri Nam quốc anh hùng chi hữu chủ!”", start: 27.5, end: 29.8 }
  ],
  4: [
    { text: "Mặc dù triều đại trị vì ngắn ngủi chỉ bốn năm ", start: 29.8, end: 32.5 },
    { text: "trước khi băng hà đột ngột, ", start: 32.5, end: 35.8 }
  ],
  5: [
    { text: "vị vua áo vải anh hùng Quang Trung - Nguyễn Huệ ", start: 35.8, end: 39.0 },
    { text: "đã khắc sâu vào trang sử Việt Nam tinh thần hành động ", start: 39.0, end: 41.0 },
    { text: "quật cường, táo bạo và quả cảm vô song.", start: 41.0, end: 42.2 }
  ]
};

interface CharacterIntroProps {
  character: any;
  onComplete: () => void;
}

export function CharacterIntro({ character, onComplete }: CharacterIntroProps) {
  const canvasRef = useRef<HTMLCanvasElement | null>(null);
  const containerRef = useRef<HTMLDivElement | null>(null);
  
  // Movie Play States
  const [isPlaying, setIsPlaying] = useState(false);
  const [activeChapter, setActiveChapter] = useState(0);
  const [currentTime, setCurrentTime] = useState(0);
  const [mousePos, setMousePos] = useState({ x: 0, y: 0 });
  const [screenShake, setScreenShake] = useState(false);
  const [movieEnded, setMovieEnded] = useState(false);
  
  const TOTAL_DURATION = 42.2; // Match exact duration of the corrected vua_quang_trung.mp3
  const rafRef = useRef<number | null>(null);

  const {
    initAudio,
    cleanup,
    voiceoverAudio
  } = useIntroAudio();

  const { triggerSplashBurst } = useIntroCanvas(canvasRef, activeChapter, currentTime / TOTAL_DURATION, mousePos);

  // Mouse move parallax
  useEffect(() => {
    const handleMove = (e: MouseEvent) => {
      setMousePos({
        x: (e.clientX / window.innerWidth - 0.5) * 2,
        y: (e.clientY / window.innerHeight - 0.5) * 2,
      });
    };
    window.addEventListener("mousemove", handleMove, { passive: true });
    return () => window.removeEventListener("mousemove", handleMove);
  }, []);

  // Update active chapter and trigger visual effects based on time
  const handleTimeTrigger = useCallback((time: number) => {
    let chapter = 0;
    if (time >= 3.8 && time < 11.5) chapter = 1;
    else if (time >= 11.5 && time < 19.5) chapter = 2;
    else if (time >= 19.5 && time < 29.8) chapter = 3;
    else if (time >= 29.8 && time < 35.8) chapter = 4;
    else if (time >= 35.8) chapter = 5;

    setActiveChapter(chapter);

    // Battle chapter effects (camera shake and sparks)
    if (chapter === 4) {
      setScreenShake(Math.random() > 0.45);
      const canvas = canvasRef.current;
      if (canvas && Math.random() < 0.18) {
        triggerSplashBurst(
          canvas.width * (0.25 + Math.random() * 0.5),
          canvas.height * (0.35 + Math.random() * 0.3),
          8
        );
      }
    } else {
      if (screenShake) setScreenShake(false);
    }
  }, [screenShake, triggerSplashBurst]);

  // Main tick animation loop
  useEffect(() => {
    if (!isPlaying) {
      if (rafRef.current) {
        cancelAnimationFrame(rafRef.current);
        rafRef.current = null;
      }
      return;
    }

    const tick = () => {
      const audio = voiceoverAudio;
      if (!audio) {
        rafRef.current = requestAnimationFrame(tick);
        return;
      }

      if (audio.paused && isPlaying) {
        audio.play().catch(() => {});
      }

      const audioTime = audio.currentTime;
      setCurrentTime(audioTime);
      handleTimeTrigger(audioTime);

      // Check end of audio
      if (audioTime >= TOTAL_DURATION || audio.ended) {
        setCurrentTime(TOTAL_DURATION);
        setIsPlaying(false);
        setMovieEnded(true);
        setScreenShake(false);
        if (rafRef.current) cancelAnimationFrame(rafRef.current);
        setTimeout(() => {
          cleanup();
          onComplete();
        }, 1200);
        return;
      }

      rafRef.current = requestAnimationFrame(tick);
    };

    rafRef.current = requestAnimationFrame(tick);
    return () => {
      if (rafRef.current) cancelAnimationFrame(rafRef.current);
    };
  }, [isPlaying, voiceoverAudio, handleTimeTrigger, onComplete, cleanup]);

  // Handle Play/Pause
  const togglePlay = () => {
    initAudio();
    if (isPlaying) {
      setIsPlaying(false);
      if (voiceoverAudio) voiceoverAudio.pause();
    } else {
      setIsPlaying(true);
      setMovieEnded(false);
      if (voiceoverAudio) {
        voiceoverAudio.currentTime = currentTime >= TOTAL_DURATION ? 0 : currentTime;
        voiceoverAudio.play().catch(e => console.warn("Blocked:", e));
      }
    }
  };

  // Skip
  const handleSkip = () => {
    cleanup();
    if (voiceoverAudio) voiceoverAudio.pause();
    onComplete();
  };

  // Replay
  const handleReplay = () => {
    initAudio();
    setScreenShake(false);
    setMovieEnded(false);
    setCurrentTime(0);
    setActiveChapter(0);
    if (voiceoverAudio) {
      voiceoverAudio.pause();
      voiceoverAudio.currentTime = 0;
    }
    setIsPlaying(true);
  };

  // Subtitle Renderer with dynamic karaoke phrase highlight
  const renderSubtitles = () => {
    const tokens = CHAPTER_SUBTITLES[activeChapter] || [];
    return (
      <div className="story-subtitle-words">
        {tokens.map((tok, idx) => {
          const isHighlighted = currentTime >= tok.start && currentTime <= tok.end;
          const isPassed = currentTime > tok.end;
          return (
            <span
              key={idx}
              className={`story-sub-phrase ${isHighlighted ? "phrase-active" : ""} ${isPassed ? "phrase-passed" : ""}`}
            >
              {tok.text}
            </span>
          );
        })}
      </div>
    );
  };

  return (
    <div
      ref={containerRef}
      className={`story-scroll-container ${screenShake ? "camera-shake-active" : ""}`}
    >
      <div className="story-content-wrapper">
        {/* ── Canvas Layer (particles, lighting) ── */}
        <canvas ref={canvasRef} className="story-canvas" />

        {/* ── Skip Button ── */}
        <button onClick={handleSkip} className="story-skip-btn">
          Bỏ qua Intro
        </button>

        {/* ── Background Slideshow Layer with crossfade & Ken Burns zoom ── */}
        <div className="story-slideshow-container">
          {/* Chapter 0: Dark Mist Opening */}
          <div className={`story-slide ${activeChapter === 0 ? "active" : ""}`}>
            <div className="story-full-bg scroll-bg-texture" />
          </div>

          {/* Chapter 1: Coronation */}
          <div className={`story-slide ${activeChapter === 1 ? "active" : ""}`}>
            <div className="story-full-bg">
              <img
                src="/images/quang_trung_coronation.png"
                alt="Nguyễn Huệ đăng quang tại núi Bân"
                className={`story-bg-image ${activeChapter === 1 && isPlaying ? "kenburns-active" : ""}`}
              />
              <div className="story-vignette-overlay" />
            </div>
          </div>

          {/* Chapter 2: Speed March */}
          <div className={`story-slide ${activeChapter === 2 ? "active" : ""}`}>
            <div className="story-full-bg">
              <img
                src="/images/quang_trung_march.png"
                alt="Hành quân thần tốc"
                className={`story-bg-image ${activeChapter === 2 && isPlaying ? "kenburns-active" : ""}`}
              />
              <div className="story-vignette-overlay fire-overlay" />
            </div>
          </div>

          {/* Chapter 3: Oath Scroll */}
          <div className={`story-slide ${activeChapter === 3 ? "active" : ""}`}>
            <div className="story-full-bg scroll-bg-texture" />
          </div>

          {/* Chapter 4: Battle */}
          <div className={`story-slide ${activeChapter === 4 ? "active" : ""}`}>
            <div className="story-full-bg">
              <img
                src="/images/quang_trung_battle.png"
                alt="Voi chiến đại phá đồn Ngọc Hồi"
                className={`story-bg-image ${activeChapter === 4 && isPlaying ? "kenburns-active" : ""}`}
              />
              <div className="story-vignette-overlay battle-overlay" />
            </div>
          </div>

          {/* Chapter 5: Victory */}
          <div className={`story-slide ${activeChapter === 5 ? "active" : ""}`}>
            <div className="story-full-bg">
              <img
                src="/images/quang_trung_victory.png"
                alt="Khải hoàn Thăng Long"
                className={`story-bg-image ${activeChapter === 5 && isPlaying ? "kenburns-active" : ""}`}
              />
              <div className="story-vignette-overlay victory-overlay" />
            </div>
          </div>
        </div>

        {/* ── Foreground Overlay elements ── */}
        <div className="story-cinematic-foreground">
          {/* Starting Cinematic Play Overlay */}
          {!isPlaying && currentTime === 0 && (
            <div className="story-play-overlay fade-in puppet-content" onClick={togglePlay}>
              <div className="story-play-overlay-content">
                <div className="story-play-icon-glow">
                  <svg viewBox="0 0 24 24" className="w-20 h-20 fill-current"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <h2 className="story-play-title text-gold-glow">ĐẠI CHIẾN NGỌC HỒI - ĐỐNG ĐA</h2>
                <p className="story-play-subtitle">BẤM VÀO ĐÂY ĐỂ BẮT ĐẦU TRẢI NGHIỆM ĐIỆN ẢNH</p>
              </div>
            </div>
          )}

          {/* Chapter 0: Narrator Opening */}
          {activeChapter === 0 && (
            <div className="puppet-content story-center-col fade-in">
              <p className="story-narrator-text text-gold-glow">
                &ldquo;Mùa xuân năm Kỷ Dậu 1789...&rdquo;
              </p>
              <div className="story-narrator-subtitle">
                Đêm giao thừa thay đổi vận mệnh giang sơn nước Nam
              </div>
            </div>
          )}

          {/* Chapter 3: Oath antique parchment paper */}
          {activeChapter === 3 && (
            <div className="puppet-content story-center-col fade-in">
              <span className="story-chapter-label text-gold-glow">
                LỜI THỀ HẠ KỲ THỆ SƯ
              </span>
              <div className="story-oath-scroll-paper">
                <div className="story-oath-body-text">
                  <p>&ldquo;Đánh cho để tóc dài,</p>
                  <p>Đánh cho để răng đen,</p>
                  <p>Đánh cho nó chích luân bất phản,</p>
                  <p>Đánh cho nó phiến giáp bất hoàn,</p>
                  <p>Đánh cho sử tri Nam quốc anh hùng chi hữu chủ!&rdquo;</p>
                </div>
              </div>
              <div className="story-oath-author">
                — Lời tuyên dụ đanh thép của Hoàng đế Quang Trung trước ba quân tướng sĩ Tây Sơn
              </div>
            </div>
          )}



          {/* Subtitle bottom bar (visible on all slides except opening and oath scroll) */}
          {activeChapter !== 0 && activeChapter !== 3 && (
            <div className="story-movie-subtitle-bar fade-in">
              <span className="story-chapter-title text-gold-glow">
                {activeChapter === 1 && "ĐĂNG QUANG NÚI BÂN (1788)"}
                {activeChapter === 2 && "GIANG SƠN LÂM NGUY"}
                {activeChapter === 4 && "ĐẠI CHIẾN NGỌC HỒI - ĐỐNG ĐA"}
                {activeChapter === 5 && "CHIẾN THẮNG HUY HOÀNG"}
              </span>
              {renderSubtitles()}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
