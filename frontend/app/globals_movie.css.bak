@tailwind base;
@tailwind components;
@tailwind utilities;

/* =============================================
   DESIGN TOKENS
   ============================================= */
:root {
  color-scheme: dark;

  /* Core palette */
  --kinpaku: #e5bd3b;
  --kinpaku-light: #f5d060;
  --patina: #25b7a6;
  --lacquer: #110f0d;
  --lacquer-deep: #090806;
  --raised: #1d1915;
  --rice: #f6f0e4;
  --ink: #2b2119;

  /* Character themes */
  --qt-gold: #d4a017;
  --qt-red: #8b1a1a;
  --qt-dark: #0d0a05;

  --thd-blue: #1a3a5c;
  --thd-silver: #c0c8d8;

  --nt-jade: #1a4a2e;
  --nt-cream: #f5f0e0;

  --hcm-crimson: #8b0000;
  --hcm-gold: #d4af37;

  --vng-navy: #0a1628;
  --vng-brass: #b8860b;

  /* Typography */
  --font-display: 'Cinzel', 'Noto Serif', serif;
  --font-body: 'Be Vietnam Pro', Arial, sans-serif;
  --font-historical: 'IM Fell English SC', serif;
}

/* =============================================
   BASE RESET
   ============================================= */
* {
  box-sizing: border-box;
}

html, body {
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

body {
  background:
    radial-gradient(circle at 14% 12%, rgba(229, 189, 59, 0.12), transparent 28rem),
    radial-gradient(circle at 92% 8%, rgba(37, 183, 166, 0.09), transparent 24rem),
    linear-gradient(135deg, #070604 0%, #130f0b 45%, #080706 100%);
  color: var(--rice);
  font-family: var(--font-body);
}

button, input, textarea, select { font: inherit; }
button { cursor: pointer; }
::selection { background: rgba(229, 189, 59, 0.32); }

/* =============================================
   SCROLLBAR
   ============================================= */
.chat-scroll {
  scrollbar-color: rgba(229, 189, 59, 0.32) transparent;
}
.chat-scroll::-webkit-scrollbar { width: 10px; }
.chat-scroll::-webkit-scrollbar-thumb {
  background: rgba(229, 189, 59, 0.28);
  border-radius: 999px;
}

/* =============================================
   SHELL LAYOUT
   ============================================= */
.shell-grid {
  display: grid;
  grid-template-columns: minmax(240px, 300px) minmax(0, 1fr) minmax(260px, 320px);
  gap: 1rem;
  min-height: 100vh;
  padding: 1rem;
}

.panel {
  border: 1px solid rgba(229, 189, 59, 0.18);
  background: rgba(17, 15, 13, 0.88);
  box-shadow: inset 0 0 0 1px rgba(246, 240, 228, 0.03);
  border-radius: 8px;
}

.surface {
  border: 1px solid rgba(229, 189, 59, 0.2);
  background: linear-gradient(180deg, rgba(29, 25, 21, 0.96), rgba(10, 9, 8, 0.98));
  border-radius: 8px;
}

.hairline { border: 1px solid rgba(229, 189, 59, 0.22); }
.text-muted { color: rgba(246, 240, 228, 0.68); }

/* =============================================
   AUDIO PLAYER
   ============================================= */
.audio-progress {
  background: linear-gradient(90deg, var(--kinpaku), #87c89c, var(--patina));
}

/* =============================================
   CHARACTER VIEWER
   ============================================= */
.character-frame {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 0.75rem;
  background:
    radial-gradient(circle at 50% 18%, rgba(229, 189, 59, 0.12), transparent 13rem),
    linear-gradient(180deg, rgba(29, 25, 21, 0.96), rgba(8, 7, 6, 0.98));
}

.character-stage {
  position: relative;
  aspect-ratio: 1 / 1;
  width: 100%;
  max-height: min(48vh, 430px);
  overflow: hidden;
  border-radius: 8px;
  border: 1px solid rgba(229, 189, 59, 0.24);
  background: linear-gradient(180deg, rgba(9, 8, 6, 0.96), rgba(18, 15, 12, 0.98));
  box-shadow:
    inset 0 0 0 1px rgba(246, 240, 228, 0.035),
    0 18px 60px rgba(0, 0, 0, 0.32);
}

.character-stage img {
  filter: drop-shadow(0 18px 26px rgba(0, 0, 0, 0.38));
}

.character-visual-caption {
  border-top: 1px solid rgba(229, 189, 59, 0.16);
  padding-top: 0.6rem;
  color: rgba(246, 240, 228, 0.68);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-family: var(--font-display);
}

/* =============================================
   RESPONSIVE
   ============================================= */
.right-rail { min-width: 0; }

@media (max-width: 1100px) {
  .shell-grid {
    grid-template-columns: 240px minmax(0, 1fr);
  }
  .right-rail { display: none; }
}

@media (max-width: 760px) {
  .shell-grid {
    grid-template-columns: 1fr;
    padding: 0.65rem;
  }
  .left-rail { order: 2; }
}

/* =============================================
   CHARACTER SELECT PAGE
   ============================================= */
.select-page {
  position: fixed;
  inset: 0;
  overflow: hidden;
  background: #06040208;
}

.select-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(139,26,26,0.18) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 20% 80%, rgba(212,160,23,0.10) 0%, transparent 50%),
    linear-gradient(160deg, #0a0704 0%, #12100c 40%, #0c0a07 100%);
  z-index: 0;
}

/* Dragon pattern overlay */
.select-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 60px,
      rgba(229,189,59,0.6) 60px,
      rgba(229,189,59,0.6) 61px
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 60px,
      rgba(229,189,59,0.6) 60px,
      rgba(229,189,59,0.6) 61px
    );
}

.select-canvas {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.select-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 100vh;
  padding: 2rem 1rem;
  overflow-y: auto;
}

/* Header */
.select-header {
  text-align: center;
  margin-bottom: 3rem;
  animation: fadeSlideDown 1s ease both;
}

.select-header-ornament {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.select-header-line {
  height: 1px;
  width: 80px;
  background: linear-gradient(90deg, transparent, rgba(229,189,59,0.8), transparent);
}

.select-header-diamond {
  width: 8px;
  height: 8px;
  background: var(--kinpaku);
  transform: rotate(45deg);
  box-shadow: 0 0 12px rgba(229,189,59,0.8);
}

.select-title {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 900;
  color: var(--kinpaku);
  text-shadow:
    0 0 40px rgba(229,189,59,0.4),
    0 2px 4px rgba(0,0,0,0.8);
  letter-spacing: 0.08em;
  line-height: 1.1;
  margin: 0 0 0.5rem;
}

.select-subtitle {
  font-family: var(--font-body);
  font-size: 1rem;
  color: rgba(246,240,228,0.6);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin: 0;
}

/* Character cards grid */
.character-cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
  width: 100%;
  max-width: 1200px;
  padding: 0 1rem;
}

@media (min-width: 900px) {
  .character-cards-grid {
    grid-template-columns: repeat(5, 1fr);
  }
}

@media (max-width: 640px) {
  .character-cards-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
}

/* Individual card */
.character-card {
  position: relative;
  border: 1px solid rgba(229,189,59,0.2);
  border-radius: 12px;
  background: rgba(17,14,10,0.85);
  cursor: pointer;
  overflow: hidden;
  transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  animation: fadeSlideUp 0.6s ease both;
  backdrop-filter: blur(4px);
}

.character-card:nth-child(1) { animation-delay: 0.1s; }
.character-card:nth-child(2) { animation-delay: 0.2s; }
.character-card:nth-child(3) { animation-delay: 0.3s; }
.character-card:nth-child(4) { animation-delay: 0.4s; }
.character-card:nth-child(5) { animation-delay: 0.5s; }

.character-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: var(--kinpaku);
  box-shadow:
    0 0 30px rgba(229,189,59,0.25),
    0 20px 60px rgba(0,0,0,0.6),
    inset 0 1px 0 rgba(229,189,59,0.15);
}

.character-card-glow {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  border-radius: inherit;
}

.character-card:hover .character-card-glow {
  opacity: 1;
}

.character-card-portrait {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  object-position: top;
  display: block;
  filter: saturate(0.85) contrast(1.05);
  transition: filter 0.3s;
}

.character-card:hover .character-card-portrait {
  filter: saturate(1.1) contrast(1.1);
}

.character-card-portrait-placeholder {
  width: 100%;
  aspect-ratio: 3/4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 900;
  color: var(--kinpaku);
  background: linear-gradient(180deg, rgba(30,20,10,0.9), rgba(10,8,5,0.95));
}

.character-card-info {
  padding: 1rem;
  background: linear-gradient(180deg, transparent, rgba(10,8,5,0.96) 30%);
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
}

.character-card-name {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--kinpaku);
  margin: 0 0 0.2rem;
  text-shadow: 0 1px 3px rgba(0,0,0,0.8);
  line-height: 1.3;
}

.character-card-era {
  font-size: 0.72rem;
  color: rgba(246,240,228,0.55);
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.character-card-badge {
  position: absolute;
  top: 0.5rem;
  right: 0.5rem;
  background: rgba(10,8,5,0.85);
  border: 1px solid rgba(229,189,59,0.3);
  border-radius: 4px;
  padding: 0.2rem 0.4rem;
  font-family: var(--font-historical);
  font-size: 0.65rem;
  color: rgba(229,189,59,0.8);
  backdrop-filter: blur(4px);
}

/* Select button on card */
.character-card-btn {
  position: absolute;
  inset: 0;
  background: transparent;
  border: none;
  cursor: pointer;
}

/* =============================================
   INTRO OVERLAY
   ============================================= */
.intro-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.intro-scene {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  opacity: 0;
  transition: opacity 0.8s ease;
}

.intro-scene.active {
  opacity: 1;
}

.intro-skip-btn {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  z-index: 10;
  background: rgba(0,0,0,0.6);
  border: 1px solid rgba(229,189,59,0.3);
  border-radius: 6px;
  color: rgba(246,240,228,0.7);
  font-family: var(--font-body);
  font-size: 0.8rem;
  padding: 0.5rem 1rem;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 0.05em;
}

.intro-skip-btn:hover {
  border-color: var(--kinpaku);
  color: var(--kinpaku);
}

.intro-progress-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--kinpaku), var(--patina));
  transition: width 0.3s linear;
}

/* Scene elements */
.intro-chinese-char {
  font-family: 'Noto Serif', serif;
  font-weight: 900;
  color: var(--kinpaku);
  text-shadow:
    0 0 60px rgba(229,189,59,0.8),
    0 0 120px rgba(229,189,59,0.4);
  animation: glowPulse 2s ease-in-out infinite;
}

.intro-year-text {
  font-family: var(--font-display);
  font-size: clamp(1.2rem, 3vw, 2rem);
  color: var(--rice);
  letter-spacing: 0.3em;
  text-transform: uppercase;
}

.intro-typewriter {
  overflow: hidden;
  white-space: nowrap;
  border-right: 3px solid var(--kinpaku);
  animation: typewriterBlink 0.75s step-end infinite;
}

.intro-typewriter.done {
  border-right: none;
}

.intro-quote {
  font-family: var(--font-historical);
  font-size: clamp(1rem, 2.5vw, 1.5rem);
  color: rgba(246,240,228,0.9);
  text-align: center;
  line-height: 1.8;
  max-width: 700px;
  font-style: italic;
  text-shadow: 0 2px 12px rgba(0,0,0,0.8);
}

.intro-quote-source {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--kinpaku);
  margin-top: 1rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.intro-stat-number {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 900;
  color: var(--kinpaku);
  text-shadow: 0 0 40px rgba(229,189,59,0.5);
  line-height: 1;
}

.intro-stat-label {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: rgba(246,240,228,0.6);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-top: 0.25rem;
}

.intro-final-btn {
  background: linear-gradient(135deg, var(--kinpaku), #b8941e);
  color: #1c150d;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  padding: 0.9rem 2.5rem;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  box-shadow: 0 4px 20px rgba(229,189,59,0.4);
  transition: all 0.2s;
  animation: fadeSlideUp 0.6s ease both;
}

.intro-final-btn:hover {
  background: linear-gradient(135deg, #f5d060, var(--kinpaku));
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(229,189,59,0.5);
}

/* SVG Map animation */
.intro-map-svg .map-path {
  stroke-dasharray: 1000;
  stroke-dashoffset: 1000;
  animation: drawPath 3s ease forwards;
}

.intro-map-svg .map-arrow {
  opacity: 0;
  animation: fadeIn 0.5s ease 3s forwards;
}

/* Lightning effect */
.lightning-overlay {
  position: absolute;
  inset: 0;
  background: rgba(255,255,220,0.15);
  opacity: 0;
  animation: lightning 0.1s ease 0.5s forwards, lightning 0.1s ease 1.2s forwards;
  pointer-events: none;
}

/* Sword slash */
.sword-slash {
  position: absolute;
  width: 3px;
  height: 0;
  background: linear-gradient(180deg, transparent, rgba(229,189,59,0.9), transparent);
  animation: swordSlash 0.4s ease 1s forwards;
}

/* Particle for intro */
.intro-particle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  animation: floatParticle linear infinite;
}

/* =============================================
   INTERACTIVE STORYTELLING STAGE (AAA Intro)
   ============================================= */

/* Lenis scroll container */
.story-scroll-container {
  position: fixed;
  inset: 0;
  z-index: 9999;
  overflow-y: auto;
  overflow-x: hidden;
  background: #030605;
  color: var(--rice);
  font-family: var(--font-body);
}

.story-content-wrapper {
  position: relative;
  width: 100%;
}

/* Background Canvas */
.story-canvas {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1;
  pointer-events: none;
}

/* Skip Button */
.story-skip-btn {
  position: fixed;
  top: 1.5rem;
  right: 1.5rem;
  z-index: 200;
  background: rgba(13, 10, 7, 0.85);
  border: 1px solid var(--kinpaku);
  border-radius: 4px;
  color: var(--rice);
  font-family: var(--font-display);
  font-size: 0.8rem;
  font-weight: 600;
  padding: 0.6rem 1.2rem;
  cursor: pointer;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  backdrop-filter: blur(8px);
  box-shadow: 0 0 15px rgba(229, 189, 59, 0.2);
  transition: all 0.3s ease;
}

.story-skip-btn:hover {
  background: var(--kinpaku);
  color: var(--lacquer-deep);
  box-shadow: 0 0 25px rgba(229, 189, 59, 0.6);
  transform: translateY(-1px);
}

/* Progress Bar */
.story-progress-bar {
  position: fixed;
  top: 0;
  left: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--kinpaku), var(--patina));
  z-index: 210;
  transition: width 0.1s ease-out;
  box-shadow: 0 0 10px var(--kinpaku);
}

/* Scroll Hint */
@keyframes storyScrollBounce {
  0%, 100% { transform: translate(-50%, 0); opacity: 0.6; }
  50% { transform: translate(-50%, 12px); opacity: 1; }
}

.story-scroll-hint {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 150;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  animation: storyScrollBounce 2.5s ease-in-out infinite;
  pointer-events: none;
}

.story-scroll-hint span {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--kinpaku);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.story-scroll-arrow {
  width: 14px;
  height: 14px;
  border-right: 2px solid var(--kinpaku);
  border-bottom: 2px solid var(--kinpaku);
  transform: rotate(45deg);
}

/* Chapter dots navigation */
.story-chapter-dots {
  position: fixed;
  right: 2rem;
  top: 50%;
  transform: translateY(-50%);
  z-index: 150;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.story-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 1px solid rgba(246, 240, 228, 0.4);
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  background: transparent;
}

.story-dot.visited {
  border-color: var(--kinpaku);
}

.story-dot.active {
  background: var(--kinpaku);
  transform: scale(1.6);
  box-shadow: 0 0 12px var(--kinpaku);
}

/* Section styling */
.story-section {
  position: relative;
  min-height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rem 2rem;
  overflow: hidden;
}

.story-z-top {
  position: relative;
  z-index: 10;
}

/* Puppet content visibility */
.puppet-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  z-index: 5;
}

.story-center-col {
  max-w: 800px;
  text-align: center;
}

/* Narrative text (Chapter 0) */
.story-narrator-text {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  color: var(--rice);
  font-style: italic;
  text-shadow: 0 0 40px rgba(246, 240, 228, 0.3);
  margin-bottom: 1.5rem;
}

.story-narrator-subtitle {
  font-family: var(--font-body);
  font-size: clamp(0.9rem, 2vw, 1.2rem);
  color: var(--kinpaku);
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

/* Puppet framing (Chapter 1) */
.story-puppet-frame {
  position: relative;
  width: min(520px, 85vw);
  aspect-ratio: 16 / 10;
  border: 6px solid var(--kinpaku);
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 
    0 25px 60px rgba(0,0,0,0.9),
    0 0 40px rgba(229,189,59,0.15);
  margin-bottom: 2.5rem;
}

.story-puppet-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle, rgba(229,189,59,0.2) 0%, transparent 80%);
  pointer-events: none;
  z-index: 2;
}

.story-puppet-image {
  width: 100%;
  height: 100%;
  object-cover: cover;
  transform: scale(1.1);
}

.story-reveal-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 900;
  color: var(--kinpaku);
  letter-spacing: 0.25em;
  text-shadow: 0 0 30px rgba(229,189,59,0.4);
  margin-bottom: 0.5rem;
}

.story-reveal-subtitle {
  font-family: var(--font-display);
  font-size: clamp(1rem, 2.5vw, 1.5rem);
  color: var(--rice);
  letter-spacing: 0.4em;
  text-transform: uppercase;
}

/* Calligraphy & cards (Chapter 2) */
.story-calligraphy {
  font-family: 'Noto Serif', serif;
  font-weight: 900;
  font-size: clamp(6rem, 15vw, 10rem);
  line-height: 1;
  color: #ff3333;
  text-shadow: 0 0 45px rgba(255,51,51,0.5);
  margin-bottom: 2rem;
}

.story-info-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
  width: 100%;
  max-width: 500px;
  margin-bottom: 2rem;
}

@media (max-width: 480px) {
  .story-info-cards {
    grid-template-columns: 1fr;
  }
}

.story-info-card {
  background: rgba(29, 25, 21, 0.7);
  border: 1px solid rgba(229, 189, 59, 0.25);
  border-radius: 6px;
  padding: 1rem;
  backdrop-filter: blur(8px);
}

.story-info-card-label {
  font-family: var(--font-body);
  font-size: 0.75rem;
  color: rgba(246, 240, 228, 0.6);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 0.25rem;
}

.story-info-card-value {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--kinpaku);
}

.story-bio-text {
  font-size: clamp(1rem, 2.5vw, 1.15rem);
  line-height: 1.8;
  color: rgba(246, 240, 228, 0.85);
  max-w: 650px;
}

/* Crisis Styling (Chapter 3) */
.story-ch-crisis {
  background: radial-gradient(circle at center, #150905 0%, #030605 100%);
}

.story-crisis-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(139, 26, 26, 0.15) 0%, transparent 70%);
  pointer-events: none;
}

.story-chapter-label {
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  display: block;
}

.story-label-red {
  color: #ff4d4d;
}

.story-label-gold {
  color: var(--kinpaku);
}

.story-crisis-title {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 900;
  line-height: 1.3;
  color: var(--rice);
  text-shadow: 0 0 30px rgba(255, 77, 77, 0.2);
  margin-bottom: 1.5rem;
}

.story-crisis-text {
  font-size: clamp(1rem, 2vw, 1.2rem);
  line-height: 1.8;
  color: rgba(246, 240, 228, 0.85);
  max-width: 600px;
  margin-bottom: 2.5rem;
}

.story-crisis-stats {
  display: flex;
  gap: 3rem;
  justify-content: center;
}

.story-stat-num {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 900;
  line-height: 1;
  margin-bottom: 0.5rem;
}

.text-red-glow {
  color: #ff4d4d;
  text-shadow: 0 0 20px rgba(255, 77, 77, 0.4);
}

/* Oath scroll styling (Chapter 4) */
.story-oath-scroll {
  background: #110e0c;
  border: 2px solid var(--kinpaku);
  border-radius: 8px;
  padding: 2rem 3rem;
  box-shadow: 
    0 15px 40px rgba(0,0,0,0.6),
    inset 0 0 30px rgba(229,189,59,0.05);
  max-width: 700px;
  margin-bottom: 1.5rem;
  position: relative;
}

.story-oath-text {
  font-family: var(--font-historical);
  font-size: clamp(1.15rem, 2.5vw, 1.45rem);
  font-style: italic;
  line-height: 2;
  color: var(--rice);
}

.story-oath-source {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--kinpaku);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 3rem;
}

.story-march-stats {
  display: flex;
  gap: 4rem;
}

.story-march-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.story-march-num {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 900;
  color: var(--kinpaku);
}

.story-march-label {
  font-family: var(--font-body);
  font-size: 0.75rem;
  color: rgba(246, 240, 228, 0.6);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-top: 0.25rem;
}

/* Battle chapter (Chapter 5) */
.story-ch-battle {
  background: #020202;
}

.story-battle-bg {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.story-battle-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.25;
}

.story-battle-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(0deg, #020202 0%, rgba(2,2,2,0.6) 50%, #020202 100%);
}

.story-battle-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 900;
  color: var(--kinpaku);
  letter-spacing: 0.2em;
  text-shadow: 0 0 35px rgba(229,189,59,0.3);
  margin-bottom: 1.5rem;
}

.story-battle-text {
  font-size: clamp(1rem, 2.5vw, 1.15rem);
  line-height: 1.8;
  color: rgba(246, 240, 228, 0.85);
  max-width: 650px;
  background: rgba(2, 2, 2, 0.7);
  backdrop-filter: blur(8px);
  padding: 1.5rem;
  border-radius: 6px;
  border: 1px solid rgba(229,189,59,0.15);
  margin-bottom: 2.5rem;
}

/* Hotspots */
.story-hotspots {
  display: flex;
  gap: 1.5rem;
  justify-content: center;
  flex-wrap: wrap;
}

.story-hotspot {
  position: relative;
  background: rgba(139, 26, 26, 0.85);
  border: 1px solid #ff4d4d;
  color: var(--rice);
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  padding: 0.6rem 1.2rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 0 15px rgba(255, 77, 77, 0.2);
}

.story-hotspot:hover {
  background: #ff4d4d;
  color: #000;
  box-shadow: 0 0 25px rgba(255, 77, 77, 0.7);
  transform: translateY(-2px);
}

.story-tooltip {
  position: absolute;
  bottom: calc(100% + 12px);
  left: 50%;
  transform: translateX(-50%);
  width: 280px;
  background: rgba(13, 10, 7, 0.95);
  border: 1px solid var(--kinpaku);
  border-radius: 6px;
  padding: 1rem;
  color: rgba(246, 240, 228, 0.9);
  font-family: var(--font-body);
  font-size: 0.8rem;
  line-height: 1.6;
  text-align: left;
  letter-spacing: 0;
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.8);
  pointer-events: none;
  animation: fadeIn 0.25s ease-out;
}

.story-tooltip::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  border-width: 6px;
  border-style: solid;
  border-color: var(--kinpaku) transparent transparent transparent;
}

/* Victory Section (Chapter 6) */
.story-ch-victory {
  background: radial-gradient(circle at center, #1b1509 0%, #030605 100%);
}

.story-victory-sunrise {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 60%, rgba(229,189,59,0.12) 0%, transparent 60%);
  pointer-events: none;
}

.story-victory-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 900;
  color: var(--kinpaku);
  letter-spacing: 0.15em;
  margin-bottom: 1.5rem;
}

.story-victory-text {
  font-size: clamp(1rem, 2.5vw, 1.15rem);
  line-height: 1.8;
  color: rgba(246, 240, 228, 0.85);
  max-width: 650px;
  margin-bottom: 3rem;
}

.story-victory-stats {
  display: flex;
  gap: 4rem;
  margin-bottom: 3.5rem;
  justify-content: center;
}

.story-v-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.story-v-num {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 900;
  color: var(--kinpaku);
}

.story-v-label {
  font-family: var(--font-body);
  font-size: 0.75rem;
  color: rgba(246, 240, 228, 0.6);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-top: 0.25rem;
}

/* CTA Button */
.story-cta-btn {
  background: linear-gradient(135deg, var(--kinpaku), #b8941e);
  color: #1c150d;
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 1.2rem 3rem;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  box-shadow: 
    0 10px 30px rgba(229,189,59,0.3),
    0 0 0 1px rgba(229,189,59,0.5);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.story-cta-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -150%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  transform: skewX(-25deg);
  transition: 0.75s;
}

.story-cta-btn:hover::before {
  left: 200%;
}

.story-cta-btn:hover {
  transform: translateY(-3px);
  box-shadow: 
    0 15px 40px rgba(229,189,59,0.5),
    0 0 15px var(--kinpaku);
}

/* Cinematic Slideshow Container & Crossfading Slides */
.story-slideshow-container {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  overflow: hidden;
}

.story-slide {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  visibility: hidden;
  transition: opacity 1.2s ease-in-out, visibility 1.2s ease-in-out;
  z-index: 1;
}

.story-slide.active {
  opacity: 1;
  visibility: visible;
  z-index: 2;
}

/* Ken Burns slow panning cinematic effect */
@keyframes kenBurns {
  0% { transform: scale(1.15) translate(0, 0); }
  100% { transform: scale(1.03) translate(-1.5%, 1%); }
}

.kenburns-active {
  animation: kenBurns 15s ease-out forwards;
}

/* Cinematic Fullscreen Background & Camera Layers */
.story-full-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 1;
}

.story-bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.story-vignette-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle, rgba(3, 6, 5, 0.25) 0%, rgba(3, 6, 5, 0.96) 85%);
  pointer-events: none;
  z-index: 3;
}

.fire-overlay {
  background: radial-gradient(circle at center, rgba(80, 25, 10, 0.32) 0%, rgba(3, 6, 5, 0.97) 90%) !important;
}

.battle-overlay {
  background: radial-gradient(circle at center, rgba(110, 30, 20, 0.42) 0%, rgba(2, 3, 2, 0.98) 95%) !important;
}

.victory-overlay {
  background: radial-gradient(circle at center, rgba(90, 55, 20, 0.22) 0%, rgba(3, 6, 5, 0.95) 90%) !important;
}

.scroll-bg-texture {
  background: radial-gradient(circle, #0f0c0a 0%, #030403 100%);
}

/* Movie Subtitle Bar / Ribbon */
.story-movie-subtitle-bar {
  position: absolute;
  bottom: 8%;
  left: 50%;
  transform: translateX(-50%);
  width: min(760px, 92vw);
  background: rgba(13, 10, 7, 0.85);
  border: 1.5px solid rgba(229, 189, 59, 0.35);
  border-radius: 8px;
  padding: 1.6rem 2.4rem;
  text-align: center;
  backdrop-filter: blur(14px);
  box-shadow: 
    0 15px 45px rgba(0,0,0,0.9),
    0 0 25px rgba(229,189,59,0.06);
  z-index: 10;
}

.story-chapter-title {
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 800;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
  display: block;
}





/* Karaoke Subtitle Word Highlight */
.story-subtitle-words {
  display: inline;
  text-align: center;
}

.story-sub-phrase {
  font-family: var(--font-body);
  font-size: clamp(0.95rem, 2.2vw, 1.15rem);
  line-height: 1.85;
  color: rgba(246, 240, 228, 0.4);
  transition: color 0.25s ease, text-shadow 0.25s ease;
  display: inline;
  margin-right: 6px;
}

.story-sub-phrase.phrase-active {
  color: var(--kinpaku) !important;
  text-shadow: 0 0 12px rgba(229, 189, 59, 0.7);
  font-weight: 700;
}

.story-sub-phrase.phrase-passed {
  color: rgba(246, 240, 228, 0.85);
}

/* Cinematic Foreground Layer */
.story-cinematic-foreground {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  pointer-events: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.story-cinematic-foreground .puppet-content {
  pointer-events: auto;
}

.story-subtitle-text {
  font-family: var(--font-body);
  font-size: clamp(0.95rem, 2.2vw, 1.1rem);
  line-height: 1.85;
  color: rgba(246, 240, 228, 0.92);
  margin: 0;
}

/* Oath Scroll (Chapter 3) */
.story-oath-scroll-paper {
  background: #15110e;
  border: 2px solid var(--kinpaku);
  border-radius: 8px;
  padding: 2.5rem 3.5rem;
  box-shadow: 
    0 25px 60px rgba(0,0,0,0.9),
    inset 0 0 45px rgba(229,189,59,0.08);
  max-width: 700px;
  margin-bottom: 1.5rem;
  position: relative;
}

.story-oath-body-text {
  font-family: var(--font-historical);
  font-size: clamp(1.2rem, 2.6vw, 1.55rem);
  font-style: italic;
  line-height: 2.15;
  color: var(--rice);
  text-shadow: 0 0 15px rgba(229,189,59,0.12);
}

.story-oath-author {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--kinpaku);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 2rem;
}





/* Lacquer Glow Overrides */
.text-gold-glow {
  color: var(--kinpaku) !important;
  text-shadow: 
    0 0 20px rgba(229, 189, 59, 0.7),
    0 0 40px rgba(229, 189, 59, 0.35) !important;
}

.text-red-neon {
  color: #ff1a1a !important;
  text-shadow: 
    0 0 25px rgba(255, 26, 26, 0.8),
    0 0 50px rgba(255, 26, 26, 0.4) !important;
}

.card-neon-gold {
  border-color: rgba(229, 189, 59, 0.45) !important;
  box-shadow: 
    0 6px 20px rgba(0,0,0,0.5),
    inset 0 0 15px rgba(229, 189, 59, 0.08),
    0 0 12px rgba(229, 189, 59, 0.15) !important;
}

/* Jitter camera shake during battle */
@keyframes cameraJitter {
  0%, 100% { transform: translate(0, 0); }
  20% { transform: translate(-4px, 3px) rotate(-0.5deg); }
  40% { transform: translate(3px, -4px) rotate(0.5deg); }
  60% { transform: translate(-3px, -3px) rotate(-0.2deg); }
  80% { transform: translate(4px, 4px) rotate(0.2deg); }
}

.camera-shake-active {
  animation: cameraJitter 0.2s infinite;
}

/* =============================================
   CONVERSATION HISTORY PANEL
   ============================================= */
.history-panel {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: min(420px, 95vw);
  background: rgba(13,10,7,0.98);
  border-left: 1px solid rgba(229,189,59,0.2);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  backdrop-filter: blur(10px);
}

.history-panel.open {
  transform: translateX(0);
}

.history-panel-header {
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid rgba(229,189,59,0.15);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.history-panel-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--kinpaku);
  margin: 0;
  letter-spacing: 0.05em;
}

.history-panel-body {
  flex: 1;
  overflow-y: auto;
  padding: 1rem;
  scrollbar-color: rgba(229,189,59,0.2) transparent;
}

.history-session-card {
  border: 1px solid rgba(229,189,59,0.12);
  border-radius: 8px;
  padding: 1rem;
  margin-bottom: 0.75rem;
  background: rgba(25,20,14,0.8);
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
}

.history-session-card:hover {
  border-color: rgba(229,189,59,0.35);
  background: rgba(40,30,15,0.8);
}

.history-session-title {
  font-family: var(--font-display);
  font-size: 0.85rem;
  color: var(--kinpaku);
  font-weight: 600;
  margin: 0 0 0.35rem;
}

.history-session-meta {
  font-size: 0.72rem;
  color: rgba(246,240,228,0.45);
  margin: 0;
}

.history-session-preview {
  font-size: 0.8rem;
  color: rgba(246,240,228,0.65);
  margin: 0.5rem 0 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.history-empty {
  text-align: center;
  padding: 3rem 1rem;
  color: rgba(246,240,228,0.35);
  font-size: 0.9rem;
}

/* =============================================
   SUGGESTED QUESTIONS
   ============================================= */
.suggested-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.75rem;
}

.suggested-question-btn {
  background: rgba(229,189,59,0.06);
  border: 1px solid rgba(229,189,59,0.18);
  border-radius: 20px;
  color: rgba(246,240,228,0.75);
  font-size: 0.78rem;
  padding: 0.35rem 0.85rem;
  cursor: pointer;
  transition: all 0.2s;
  text-align: left;
  line-height: 1.4;
}

.suggested-question-btn:hover {
  border-color: var(--kinpaku);
  color: var(--kinpaku);
  background: rgba(229,189,59,0.12);
}

/* =============================================
   CHAT AVATAR (historical style, no icons)
   ============================================= */
.chat-avatar {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-historical);
  font-size: 0.9rem;
  font-weight: 700;
}

.chat-avatar-user {
  background: linear-gradient(135deg, #6b2c2c, #8b3a3a);
  color: rgba(246,240,228,0.9);
  border: 1px solid rgba(139,58,58,0.5);
}

.chat-avatar-assistant {
  background: linear-gradient(135deg, #2a1f0a, #3d2e0f);
  color: var(--kinpaku);
  border: 1px solid rgba(229,189,59,0.3);
}

/* =============================================
   SECTION LABELS (historical style)
   ============================================= */
.section-label {
  font-family: var(--font-display);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(229,189,59,0.7);
  margin-bottom: 0.75rem;
}

.section-label::before {
  content: '◈ ';
  opacity: 0.7;
}

/* =============================================
   KEYFRAME ANIMATIONS
   ============================================= */
@keyframes fadeSlideDown {
  from { opacity: 0; transform: translateY(-24px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes glowPulse {
  0%, 100% { text-shadow: 0 0 40px rgba(229,189,59,0.6), 0 0 80px rgba(229,189,59,0.2); }
  50%       { text-shadow: 0 0 80px rgba(229,189,59,1.0), 0 0 160px rgba(229,189,59,0.5); }
}

@keyframes typewriterBlink {
  from, to { border-color: transparent; }
  50%       { border-color: var(--kinpaku); }
}

@keyframes drawPath {
  to { stroke-dashoffset: 0; }
}

@keyframes lightning {
  0%   { opacity: 0; }
  50%  { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes swordSlash {
  from { height: 0; top: 50%; opacity: 1; }
  to   { height: 200px; top: 30%; opacity: 0; }
}

@keyframes floatParticle {
  from { transform: translateY(100vh) rotate(0deg); opacity: 0.6; }
  to   { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
}

@keyframes drumBeat {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50%       { transform: scale(1.06); opacity: 1; }
}

@keyframes counterUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes mapArrowBounce {
  0%, 100% { transform: translateX(0); }
  50%       { transform: translateX(6px); }
}

@keyframes shimmer {
  0%   { background-position: -200% center; }
  100% { background-position: 200% center; }
}

@keyframes scaleIn {
  from { transform: scale(0.85); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}

@keyframes slideInLeft {
  from { transform: translateX(-60px); opacity: 0; }
  to   { transform: translateX(0); opacity: 1; }
}

@keyframes slideInRight {
  from { transform: translateX(60px); opacity: 0; }
  to   { transform: translateX(0); opacity: 1; }
}

@keyframes rotateGlow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

@keyframes waveY {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-8px); }
}

/* Starting Cinematic Play Overlay */
.story-play-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle, rgba(13, 10, 7, 0.75) 0%, rgba(3, 4, 3, 0.98) 100%);
  backdrop-filter: blur(12px);
  z-index: 100;
  cursor: pointer;
}

.story-play-overlay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.5rem;
  pointer-events: none;
}

.story-play-icon-glow {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: rgba(13, 10, 7, 0.9);
  border: 2px solid var(--kinpaku);
  color: var(--kinpaku);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 0 30px rgba(229, 189, 59, 0.4),
    inset 0 0 15px rgba(229, 189, 59, 0.2);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s;
  animation: pulseGlow 2s infinite alternate;
}

.story-play-overlay:hover .story-play-icon-glow {
  transform: scale(1.15);
  border-color: #fff;
  color: #fff;
  box-shadow: 
    0 0 45px rgba(229, 189, 59, 0.7),
    inset 0 0 25px rgba(229, 189, 59, 0.4);
}

@keyframes pulseGlow {
  0% { box-shadow: 0 0 20px rgba(229, 189, 59, 0.3); }
  100% { box-shadow: 0 0 40px rgba(229, 189, 59, 0.6); }
}

.story-play-title {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 900;
  letter-spacing: 0.15em;
  margin: 0;
}

.story-play-subtitle {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 700;
  color: rgba(246, 240, 228, 0.55);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin: 0;
}
